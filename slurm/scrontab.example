# ============================================================
# Yale Bouchet — scrontab for DM Agent
#
# Install:   scrontab slurm/scrontab.example
# Verify:    scrontab -l
# Edit:      scrontab -e
# Remove:    scrontab -r
#
# This runs the agent every Sunday at 2 AM on the 'day'
# partition. No login node cron needed.
# ============================================================

#SCRON -p day
#SCRON -J dm-agent
#SCRON --cpus-per-task=1
#SCRON --mem=2G
#SCRON --time=01:00:00
#SCRON -o /home/yz2489/dm_agent_logs/dm-agent_%j.log
#SCRON -e /home/yz2489/dm_agent_logs/dm-agent_%j.err
0 2 * * 0 /home/yz2489/data_management_agent/slurm/agent_job.sbatch
